---
import Layout from '../layouts/Layout.astro';

// ── Recent updates — edit this list whenever you ship something new ──────────
// Each update can optionally include a `link` field pointing to a Substack article.
// Example:
//   { date: 'April 2026', title: 'New feature', description: '...', link: 'https://yoursubstack.substack.com/p/...' }
const updates = [
  {
    date: 'February 10, 2026',
    title: 'You Asked, We Built: What\'s New in Chessalyz (Spring 2026 Updates)',
    description: 'A round-up of the latest features and improvements shipped based on community feedback.',
    link: 'https://chesschatter.substack.com/p/chessalyz-february-2026-update',
  },
  {
    date: 'January 16, 2026',
    title: 'We Just Made a Big Upgrade to Chessalyz.ai\'s Feedback Algorithm',
    description: 'The feedback engine got a major overhaul — here\'s what changed and why it matters.',
    link: 'https://chesschatter.substack.com/p/chessalyz-ai-feedback-upgrade',
  },
];
---

<Layout
  title="Chessalyz.ai — AI-Powered Chess Analysis by FM Dalton Perrine"
  description="Chessalyz.ai is an AI-powered chess analysis tool built by FM Dalton Perrine. Join the community to get access and stay up to date on new features."
>

  <!-- ═══════════════════════════════════════════════════════════════════════
       SECTION 1 — HERO
  ════════════════════════════════════════════════════════════════════════ -->
  <section class="bg-navy relative overflow-hidden">
    <div
      aria-hidden="true"
      class="absolute inset-0 opacity-[0.035] pointer-events-none"
      style="background-image: repeating-conic-gradient(#fff 0% 25%, transparent 0% 50%); background-size: 72px 72px;"
    ></div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28 text-center">
      <span class="inline-block font-inter text-gold text-xs font-semibold tracking-[0.2em] uppercase mb-5">
        A project by FM Dalton Perrine and Varun Kumar
      </span>
      <h1 class="font-playfair text-white text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight mb-5">
        Chessalyz.ai
      </h1>
      <p class="font-inter text-off-white/70 text-lg max-w-2xl mx-auto leading-relaxed mb-10">
        An AI-powered chess analysis tool we've been building to help players at every level understand their games more deeply and improve faster.
      </p>
      <a
        href="https://chessalyz.ai/"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-gold text-base py-3 px-8 inline-block"
      >
        Visit the Site →
      </a>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════════
       SECTION 2 — WHAT IS CHESSALYZ.AI
  ════════════════════════════════════════════════════════════════════════ -->
  <section class="bg-off-white section-pad">
    <div class="container-max">
      <div class="max-w-3xl mx-auto">

        <div class="text-center mb-12">
          <h2 class="font-playfair text-navy text-3xl sm:text-4xl font-bold mb-4">
            What Is Chessalyz.ai?
          </h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">

          <div class="card flex flex-col gap-3">
            <div class="text-2xl" aria-hidden="true">♟️</div>
            <h3 class="font-playfair text-navy text-xl font-semibold">Deep Game Analysis</h3>
            <p class="font-inter text-text-secondary text-sm leading-relaxed">
              Go beyond engine arrows. Chessalyz.ai explains the <em>why</em> behind the moves, in plain English, so you actually learn from every game you play.
            </p>
          </div>

          <div class="card flex flex-col gap-3">
            <div class="text-2xl" aria-hidden="true">🧠</div>
            <h3 class="font-playfair text-navy text-xl font-semibold">Built for Improvement</h3>
            <p class="font-inter text-text-secondary text-sm leading-relaxed">
              Whether you're a beginner or an experienced club player, the feedback is tailored to your level. No jargon, just actionable insights.
            </p>
          </div>

          <div class="card flex flex-col gap-3">
            <div class="text-2xl" aria-hidden="true">🤝</div>
            <h3 class="font-playfair text-navy text-xl font-semibold">Community-Driven</h3>
            <p class="font-inter text-text-secondary text-sm leading-relaxed">
              The Skool community is the home base for Chessalyz.ai. Early access, feature requests, and direct feedback all happen there.
            </p>
          </div>

          <div class="card flex flex-col gap-3">
            <div class="text-2xl" aria-hidden="true">🚀</div>
            <h3 class="font-playfair text-navy text-xl font-semibold">Actively Developing</h3>
            <p class="font-inter text-text-secondary text-sm leading-relaxed">
              Chessalyz.ai is in active development and shipping updates regularly. The best way to follow along is to join the community below.
            </p>
          </div>

        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════════
       SECTION 3 — SKOOL CTA
  ════════════════════════════════════════════════════════════════════════ -->
  <section class="bg-white section-pad">
    <div class="container-max">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="font-playfair text-navy text-3xl sm:text-4xl font-bold mb-4">
          Join the Chessalyz.ai Community
        </h2>
        <p class="font-inter text-text-secondary text-base leading-relaxed mb-8">
          Everything Chessalyz.ai (early access, updates, discussions, and feedback) lives in the Skool community. Come join us and help shape where the product goes next.
        </p>
        <a
          href="https://www.skool.com/chessalyz-5973"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-gold text-base py-3 px-8 inline-block"
        >
          Go to Skool Community →
        </a>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════════
       SECTION 4 — RECENT UPDATES
       To add a new update, insert a new object at the TOP of the `updates`
       array in the frontmatter above.
  ════════════════════════════════════════════════════════════════════════ -->
  <section class="bg-off-white section-pad">
    <div class="container-max">

      <div class="text-center mb-10">
        <h2 class="font-playfair text-navy text-3xl sm:text-4xl font-bold mb-3">
          Recent Updates
        </h2>
        <p class="font-inter text-text-secondary text-base">
          What's been shipping lately.
        </p>
      </div>

      <div class="max-w-2xl mx-auto flex flex-col gap-5">
        {updates.map(({ date, title, description, link }) => (
          <div class="card flex flex-col gap-2">
            <div class="flex items-center gap-3">
              <span class="font-inter text-gold text-xs font-semibold tracking-wide uppercase">{date}</span>
            </div>
            <h3 class="font-playfair text-navy text-xl font-semibold leading-snug">{title}</h3>
            <p class="font-inter text-text-secondary text-sm leading-relaxed">{description}</p>
            {link && (
              <a
                href={link}
                target="_blank"
                rel="noopener noreferrer"
                class="font-inter text-gold text-sm font-medium hover:underline mt-1 self-start"
              >
                Read on Substack →
              </a>
            )}
          </div>
        ))}
      </div>

    </div>
  </section>


</Layout>
