---
/**
 * src/pages/admin/recordings.astro
 *
 * Lesson Recordings — full CRUD admin page.
 *
 * CREATE: multi-student, one row per student inserted for the same video.
 * EDIT:   single-row update (title, date, URL, notes).
 * DELETE: single row.
 * FILTER: ?student=ID query param to show one student's recordings.
 */
export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabaseAdmin, getAllStudents } from '../../lib/supabase-admin';
import { validateVideoUrl } from '../../lib/video';

let flashSuccess = Astro.url.searchParams.get('success') ?? '';
let flashError   = '';

// ── POST handlers ─────────────────────────────────────────────────────────────
if (Astro.request.method === 'POST') {
  const form   = await Astro.request.formData();
  const action = form.get('action')?.toString() ?? '';

  // ── CREATE (one row per selected student) ───────────────────────────────
  if (action === 'create') {
    const studentIds = form.getAll('student_ids[]').map(String).filter(Boolean);
    const title      = form.get('title')?.toString().trim() ?? '';
    const lessonDate = form.get('lesson_date')?.toString() ?? '';
    const videoUrl   = form.get('video_url')?.toString().trim() ?? '';
    const notes      = form.get('notes')?.toString().trim() || null;

    if (!title)         flashError = 'Title is required.';
    else if (!lessonDate) flashError = 'Lesson date is required.';
    else if (!videoUrl)   flashError = 'Video URL is required.';
    else if (studentIds.length === 0) flashError = 'Select at least one student.';
    else {
      const rows = studentIds.map((sid) => ({
        student_id:  sid,
        title,
        lesson_date: lessonDate,
        video_url:   videoUrl,
        notes,
      }));
      const { error } = await supabaseAdmin.from('lesson_recordings').insert(rows);
      if (error) flashError = error.message;
      else return Astro.redirect(`/admin/recordings?success=${encodeURIComponent(`Recording added for ${studentIds.length} student(s)`)}`);
    }
  }

  // ── EDIT ────────────────────────────────────────────────────────────────
  if (action === 'edit') {
    const id         = form.get('id')?.toString() ?? '';
    const title      = form.get('title')?.toString().trim() ?? '';
    const lessonDate = form.get('lesson_date')?.toString() ?? '';
    const videoUrl   = form.get('video_url')?.toString().trim() ?? '';
    const notes      = form.get('notes')?.toString().trim() || null;

    if (!title)         flashError = 'Title is required.';
    else if (!lessonDate) flashError = 'Lesson date is required.';
    else if (!videoUrl)   flashError = 'Video URL is required.';
    else {
      const { error } = await supabaseAdmin.from('lesson_recordings').update({
        title, lesson_date: lessonDate, video_url: videoUrl, notes,
      }).eq('id', id);
      if (error) flashError = error.message;
      else return Astro.redirect(`/admin/recordings?success=Recording+updated`);
    }
  }

  // ── DELETE ──────────────────────────────────────────────────────────────
  if (action === 'delete') {
    const id = form.get('id')?.toString() ?? '';
    const { error } = await supabaseAdmin.from('lesson_recordings').delete().eq('id', id);
    if (error) flashError = error.message;
    else return Astro.redirect('/admin/recordings?success=Recording+deleted');
  }
}

// ── Fetch data ────────────────────────────────────────────────────────────────
const filterStudentId = Astro.url.searchParams.get('student') ?? '';
const editId          = Astro.url.searchParams.get('edit')    ?? '';

// All recordings with student name
let query = supabaseAdmin
  .from('lesson_recordings')
  .select('*, student:students(id, name)')
  .order('lesson_date', { ascending: false });

if (filterStudentId) {
  query = query.eq('student_id', filterStudentId);
}

const { data: recordings = [] } = await query;

// All active students (for add form and filter dropdown)
const students = await getAllStudents();
const activeStudents = students.filter((s: any) => s.is_active);

// Helper maps
const studentMap: Record<string, any> = {};
for (const s of students) studentMap[(s as any).id] = s;

// ── Helpers ───────────────────────────────────────────────────────────────────
function formatDate(d: string | null) {
  if (!d) return '—';
  return new Date(d + 'T00:00:00').toLocaleDateString('en-US', {
    weekday: 'short', month: 'short', day: 'numeric', year: 'numeric',
  });
}

// Today's date as YYYY-MM-DD for default values
const today = new Date().toISOString().split('T')[0];

// Auto-suggest title
const suggestTitle = `Lesson Recording – ${new Date().toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}`;
---

<AdminLayout title="Lesson Recordings | Admin">

  <!-- Page header -->
  <div class="bg-white border-b border-gray-200 px-4 sm:px-6 lg:px-8 py-5 max-w-7xl mx-auto w-full
              flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-navy font-playfair">Lesson Recordings</h1>
      <p class="text-gray-500 text-sm mt-0.5">
        {recordings.length} recording{recordings.length !== 1 ? 's' : ''}
        {filterStudentId && studentMap[filterStudentId]
          ? ` for ${(studentMap[filterStudentId] as any).name}`
          : ' total'}
      </p>
    </div>
    <button id="show-add-form"
            class="inline-flex items-center gap-2 bg-gold text-navy font-semibold px-4 py-2 rounded-lg
                   text-sm hover:bg-gold-hover transition-colors">
      + Add Recording
    </button>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-6">

    <!-- Flash messages -->
    {flashSuccess && (
      <div class="bg-emerald-50 border border-emerald-200 text-emerald-800 rounded-lg px-4 py-3 text-sm">
        ✅ {flashSuccess}
      </div>
    )}
    {flashError && (
      <div class="bg-red-50 border border-red-200 text-red-700 rounded-lg px-4 py-3 text-sm">
        ⚠️ {flashError}
      </div>
    )}

    <!-- ── Add Recording Form (hidden by default) ─────────────────────────── -->
    <div id="add-form-wrap" class="hidden bg-white rounded-xl border border-gray-200 shadow-sm p-6">
      <h2 class="font-semibold text-navy mb-5 text-lg">Add New Recording</h2>
      <form method="POST">
        <input type="hidden" name="action" value="create" />

        <!-- Students (multi-select via checkboxes) -->
        <div class="mb-5">
          <label class="block text-sm font-medium text-gray-700 mb-2">
            Student(s) <span class="text-red-500">*</span>
            <span class="text-gray-400 font-normal ml-1">— select multiple for group lessons</span>
          </label>
          {activeStudents.length === 0 ? (
            <p class="text-gray-400 text-sm italic">No active students. <a href="/admin/students" class="text-gold underline">Add students first →</a></p>
          ) : (
            <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-2">
              {activeStudents.map((s: any) => (
                <label class="flex items-center gap-2 px-3 py-2 rounded-lg border border-gray-200
                               hover:bg-gold/5 hover:border-gold/40 cursor-pointer transition-colors
                               add-student-label">
                  <input type="checkbox" name="student_ids[]" value={s.id}
                         class="rounded text-gold focus:ring-gold add-student-cb" />
                  <span class="text-sm text-navy">{s.name}</span>
                </label>
              ))}
            </div>
          )}
        </div>

        <div class="grid sm:grid-cols-2 gap-4 mb-4">
          <!-- Title -->
          <div class="sm:col-span-2">
            <label class="block text-sm font-medium text-gray-700 mb-1">
              Title <span class="text-red-500">*</span>
            </label>
            <input type="text" name="title" required
                   placeholder={suggestTitle}
                   class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm
                          focus:outline-none focus:ring-2 focus:ring-gold focus:border-transparent" />
          </div>

          <!-- Lesson Date -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
              Lesson Date <span class="text-red-500">*</span>
            </label>
            <input type="date" name="lesson_date" required value={today}
                   class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm
                          focus:outline-none focus:ring-2 focus:ring-gold focus:border-transparent" />
          </div>
        </div>

        <!-- Google Drive URL -->
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-700 mb-1">
            Google Drive Video URL <span class="text-red-500">*</span>
          </label>
          <input type="url" name="video_url" required id="add-video-url"
                 placeholder="https://drive.google.com/file/d/…/view?usp=sharing"
                 class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm
                        focus:outline-none focus:ring-2 focus:ring-gold focus:border-transparent" />
          <p class="mt-1.5 text-xs text-gray-500">
            Paste the Google Drive sharing link. Make sure the video's sharing is set to
            <strong>"Anyone with the link can view."</strong>
          </p>
          <p id="add-url-warning" class="mt-1 text-xs text-amber-600 hidden"></p>
        </div>

        <!-- Coach Notes -->
        <div class="mb-5">
          <label class="block text-sm font-medium text-gray-700 mb-1">
            Coach Notes <span class="text-gray-400">(optional — shown to student)</span>
          </label>
          <textarea name="notes" rows="3"
                    placeholder="e.g. We covered the Reti–Nimzo–Larsen mainline with 3...d5 and reviewed your game from the weekend tournament. Focus on the pawn structure ideas we discussed."
                    class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm
                           focus:outline-none focus:ring-2 focus:ring-gold focus:border-transparent resize-y"></textarea>
        </div>

        <div class="flex items-center gap-3">
          <button type="submit"
                  class="bg-gold text-navy font-semibold px-5 py-2.5 rounded-lg text-sm
                         hover:bg-gold-hover transition-colors">
            💾 Save Recording
          </button>
          <button type="button" id="hide-add-form"
                  class="bg-white text-navy font-medium px-5 py-2 rounded-lg text-sm
                         border border-gray-200 hover:bg-gray-50 transition-colors">
            Cancel
          </button>
        </div>
      </form>
    </div>

    <!-- ── Filter by student ──────────────────────────────────────────────── -->
    <div class="flex flex-wrap items-center gap-3">
      <label class="text-sm font-medium text-gray-700">Filter by student:</label>
      <form method="GET" class="inline-flex items-center gap-2">
        <select name="student" onchange="this.form.submit()"
                class="border border-gray-300 rounded-lg px-3 py-1.5 text-sm text-navy
                       focus:outline-none focus:ring-2 focus:ring-gold bg-white">
          <option value="">All Students</option>
          {activeStudents.map((s: any) => (
            <option value={s.id} selected={filterStudentId === s.id}>{s.name}</option>
          ))}
        </select>
        {filterStudentId && (
          <a href="/admin/recordings" class="text-xs text-gold underline">Clear</a>
        )}
      </form>
    </div>

    <!-- ── Recordings table ───────────────────────────────────────────────── -->
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
      {recordings.length === 0 ? (
        <div class="px-6 py-16 text-center text-gray-400 italic text-sm">
          No recordings yet
          {filterStudentId ? ' for this student.' : '.'}
          {' '}
          <button id="show-add-form-empty"
                  class="text-gold underline cursor-pointer">
            Add the first one →
          </button>
        </div>
      ) : (
        <table class="w-full">
          <thead class="bg-navy">
            <tr>
              <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider">Student</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider">Title</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider hidden sm:table-cell">Lesson Date</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider hidden lg:table-cell">Notes</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody>
            {recordings.map((r: any) => (
              <>
              <tr class="border-t border-gray-100 hover:bg-gray-50 transition-colors">
                <td class="px-4 py-3">
                  <span class="font-medium text-navy text-sm">
                    {r.student?.name ?? '—'}
                  </span>
                </td>
                <td class="px-4 py-3">
                  <p class="font-medium text-navy text-sm">{r.title}</p>
                  <a href={r.video_url} target="_blank" rel="noopener"
                     class="text-xs text-gold underline mt-0.5 inline-block">
                    Open in Drive ↗
                  </a>
                </td>
                <td class="px-4 py-3 text-gray-500 text-sm hidden sm:table-cell">
                  {formatDate(r.lesson_date)}
                </td>
                <td class="px-4 py-3 hidden lg:table-cell">
                  {r.notes ? (
                    <p class="text-gray-500 text-xs truncate max-w-xs" title={r.notes}>{r.notes}</p>
                  ) : (
                    <span class="text-gray-300 text-xs italic">—</span>
                  )}
                </td>
                <td class="px-4 py-3">
                  <div class="flex items-center gap-2">
                    <a href={`/admin/recordings?edit=${r.id}`}
                       class="text-navy hover:text-gold text-xs font-medium underline underline-offset-2">
                      Edit
                    </a>
                    <form method="POST" class="inline"
                          onsubmit="return confirm('Delete this recording? This cannot be undone.')">
                      <input type="hidden" name="action" value="delete" />
                      <input type="hidden" name="id"     value={r.id} />
                      <button type="submit"
                              class="text-red-500 hover:text-red-700 text-xs font-medium underline underline-offset-2">
                        Delete
                      </button>
                    </form>
                  </div>
                </td>
              </tr>

              {/* Inline edit form */}
              {editId === r.id && (
                <tr class="bg-gold/5 border-t border-gold/30">
                  <td colspan="5" class="px-4 py-5">
                    <h3 class="font-semibold text-navy mb-4 text-sm">Editing: {r.title}</h3>
                    <form method="POST">
                      <input type="hidden" name="action" value="edit" />
                      <input type="hidden" name="id"     value={r.id} />

                      <div class="grid sm:grid-cols-2 gap-4 mb-4">
                        <div class="sm:col-span-2">
                          <label class="block text-xs font-medium text-gray-700 mb-1">Title *</label>
                          <input type="text" name="title" required value={r.title}
                                 class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm
                                        focus:outline-none focus:ring-2 focus:ring-gold focus:border-transparent" />
                        </div>
                        <div>
                          <label class="block text-xs font-medium text-gray-700 mb-1">Lesson Date *</label>
                          <input type="date" name="lesson_date" required value={r.lesson_date}
                                 class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm
                                        focus:outline-none focus:ring-2 focus:ring-gold focus:border-transparent" />
                        </div>
                      </div>

                      <div class="mb-4">
                        <label class="block text-xs font-medium text-gray-700 mb-1">Google Drive Video URL *</label>
                        <input type="url" name="video_url" required value={r.video_url}
                               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm
                                      focus:outline-none focus:ring-2 focus:ring-gold focus:border-transparent" />
                        <p class="mt-1 text-xs text-gray-500">
                          Paste the Google Drive sharing link. Sharing must be set to "Anyone with the link can view."
                        </p>
                      </div>

                      <div class="mb-4">
                        <label class="block text-xs font-medium text-gray-700 mb-1">Coach Notes (optional)</label>
                        <textarea name="notes" rows="3"
                                  class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm
                                         focus:outline-none focus:ring-2 focus:ring-gold focus:border-transparent resize-y"
                        >{r.notes ?? ''}</textarea>
                      </div>

                      <div class="flex items-center gap-3">
                        <button type="submit"
                                class="bg-gold text-navy font-semibold px-4 py-1.5 rounded-lg text-sm
                                       hover:bg-gold-hover transition-colors">
                          Save Changes
                        </button>
                        <a href="/admin/recordings"
                           class="bg-white text-navy font-medium px-4 py-1.5 rounded-lg text-sm
                                  border border-gray-200 hover:bg-gray-50 transition-colors">
                          Cancel
                        </a>
                      </div>
                    </form>
                  </td>
                </tr>
              )}
              </>
            ))}
          </tbody>
        </table>
      )}
    </div>

  </div>
</AdminLayout>

<script is:inline>
  // Toggle add form
  function showAddForm() {
    document.getElementById('add-form-wrap')?.classList.remove('hidden');
    document.getElementById('show-add-form')?.classList.add('hidden');
  }
  document.getElementById('show-add-form')?.addEventListener('click', showAddForm);
  document.getElementById('show-add-form-empty')?.addEventListener('click', showAddForm);
  document.getElementById('hide-add-form')?.addEventListener('click', () => {
    document.getElementById('add-form-wrap')?.classList.add('hidden');
    document.getElementById('show-add-form')?.classList.remove('hidden');
  });

  // Student checkbox styling
  document.querySelectorAll('.add-student-cb').forEach((cb) => {
    cb.addEventListener('change', () => {
      const lbl = cb.closest('label');
      lbl?.classList.toggle('bg-gold/10', cb.checked);
      lbl?.classList.toggle('border-gold', cb.checked);
    });
  });

  // URL validation warning
  const urlInput = document.getElementById('add-video-url');
  const urlWarn  = document.getElementById('add-url-warning');
  urlInput?.addEventListener('blur', () => {
    const val = urlInput.value.trim();
    if (!val) { urlWarn.classList.add('hidden'); return; }
    const isDrive = val.includes('drive.google.com') || val.includes('docs.google.com');
    if (!isDrive) {
      urlWarn.textContent = '⚠️ This doesn\'t look like a Google Drive link. Make sure sharing is set to "Anyone with the link can view."';
      urlWarn.classList.remove('hidden');
    } else {
      urlWarn.classList.add('hidden');
    }
  });
</script>
