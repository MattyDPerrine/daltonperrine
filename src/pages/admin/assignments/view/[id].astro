---
/**
 * src/pages/admin/assignments/view/[id].astro
 * Preview an assignment + see all student statuses and notes.
 */
export const prerender = false;

import AdminLayout   from '../../../../layouts/AdminLayout.astro';
import { supabaseAdmin } from '../../../../lib/supabase-admin';

const { id } = Astro.params;
if (!id) return Astro.redirect('/admin/assignments');

// ── Fetch assignment with items ───────────────────────────────────────────────
const { data: assignment } = await supabaseAdmin
  .from('assignments')
  .select('*, assignment_items(*)')
  .eq('id', id)
  .single();

if (!assignment) return Astro.redirect('/admin/assignments');

const items = [...(assignment.assignment_items ?? [])].sort(
  (a: any, b: any) => a.item_order - b.item_order,
);

// ── Fetch student statuses ─────────────────────────────────────────────────────
const { data: studentStatuses = [] } = await supabaseAdmin
  .from('student_assignments')
  .select('*, student:students(name, email, access_token)')
  .eq('assignment_id', id)
  .order('assigned_at');

const success = Astro.url.searchParams.get('success') ?? '';

function formatDate(d: string | null) {
  if (!d) return '—';
  return new Date(d).toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric', year: 'numeric' });
}

const statusLabel: Record<string,string> = {
  pending:     '⬜ Not Started',
  in_progress: '🔄 In Progress',
  completed:   '✅ Completed',
};
const statusClass: Record<string,string> = {
  pending:     'bg-gray-100 text-gray-600',
  in_progress: 'bg-amber-50 text-amber-700 border border-amber-200',
  completed:   'bg-emerald-50 text-emerald-700 border border-emerald-200',
};

const BASE_URL = Astro.site ? Astro.site.href.replace(/\/$/, '') : 'https://daltonperrine.com';
---

<AdminLayout title={`View: ${assignment.title} | Admin`}>
  <slot name="head">
    <link rel="stylesheet" href="https://unpkg.com/chessground@9.1.1/assets/chessground.base.css" />
    <link rel="stylesheet" href="https://unpkg.com/chessground@9.1.1/assets/chessground.brown.css" />
    <link rel="stylesheet" href="https://unpkg.com/chessground@9.1.1/assets/chessground.cburnett.css" />
  </slot>

  <!-- Page header -->
  <div class="bg-white border-b border-gray-200 px-4 sm:px-6 lg:px-8 py-5 max-w-7xl mx-auto w-full">
    <div class="flex items-start justify-between gap-4 flex-wrap">
      <div>
        <a href="/admin/assignments" class="text-gray-400 hover:text-navy text-sm mb-1 inline-block">← Assignments</a>
        <h1 class="text-2xl font-bold text-navy font-playfair">{assignment.title}</h1>
        {assignment.lesson_date && (
          <p class="text-gray-500 text-sm mt-0.5">
            Lesson: {formatDate(assignment.lesson_date)}
          </p>
        )}
      </div>
      <div class="flex items-center gap-3">
        <a href={`/admin/assignments/edit/${id}`}
           class="inline-flex items-center gap-2 bg-gold text-navy font-semibold px-4 py-2 rounded-lg
                  text-sm hover:bg-gold-hover transition-colors">
          ✏️ Edit Assignment
        </a>
      </div>
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-8">

    {success && (
      <div class="bg-emerald-50 border border-emerald-200 text-emerald-800 rounded-lg px-4 py-3 text-sm">
        ✅ {success}
      </div>
    )}

    <!-- ── Assignment preview ─────────────────────────────────────────── -->
    <div>
      <h2 class="font-semibold text-navy mb-4 text-lg flex items-center gap-2">
        📋 Assignment Content
        <span class="text-xs font-normal text-gray-400">(as seen by students)</span>
      </h2>

      {items.length === 0 ? (
        <div class="bg-white rounded-xl border border-dashed border-gray-300 px-6 py-10 text-center text-gray-400 italic text-sm">
          No items in this assignment yet.
          <a href={`/admin/assignments/edit/${id}`} class="text-gold underline ml-1">Add items →</a>
        </div>
      ) : (
        <div class="space-y-4">
          {items.map((item: any) => (
            <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
              {/* Item label */}
              <div class="flex items-center gap-2 mb-3">
                <span class="text-xs bg-navy/8 text-navy px-2 py-0.5 rounded-full font-medium uppercase tracking-wide">
                  {item.item_type === 'text'  && '📝 Text'}
                  {item.item_type === 'fen'   && '♟ FEN Position'}
                  {item.item_type === 'pgn'   && '📖 PGN'}
                  {item.item_type === 'file'  && '📎 File'}
                  {item.item_type === 'link'  && '🔗 Link'}
                </span>
                {item.timer_seconds && (
                  <span class="text-xs bg-amber-50 text-amber-700 px-2 py-0.5 rounded-full font-medium">
                    ⏱ {Math.floor(item.timer_seconds / 60)}:{String(item.timer_seconds % 60).padStart(2,'0')}
                  </span>
                )}
              </div>

              {item.title && (
                <h3 class="font-semibold text-navy text-sm mb-2">{item.title}</h3>
              )}

              {item.item_type === 'text' && (
                <p class="text-gray-700 text-sm whitespace-pre-wrap">{item.content}</p>
              )}

              {item.item_type === 'fen' && (
                <div>
                  <code class="block bg-gray-50 border border-gray-200 rounded-lg p-3 text-xs font-mono text-navy break-all mb-3">
                    {item.content}
                  </code>
                  {/* Mini board preview */}
                  <div
                    class="fen-preview-board"
                    data-fen={item.content}
                    data-orientation={item.metadata?.orientation ?? 'white'}
                    style="width:220px;height:220px;border:1px solid #d1d5db;border-radius:4px;overflow:hidden;"
                  ></div>
                </div>
              )}

              {item.item_type === 'pgn' && (
                <pre class="bg-gray-50 border border-gray-200 rounded-lg p-3 text-xs font-mono text-navy overflow-x-auto whitespace-pre-wrap">
                  {item.content}
                </pre>
              )}

              {item.item_type === 'link' && (
                <a href={item.content} target="_blank" rel="noopener noreferrer"
                   class="inline-flex items-center gap-2 text-gold underline underline-offset-2 text-sm font-medium">
                  {item.title ?? item.content} ↗
                </a>
              )}

              {item.item_type === 'file' && item.file_url && (
                <a href={item.file_url} target="_blank" rel="noopener noreferrer"
                   class="inline-flex items-center gap-2 bg-navy/5 hover:bg-navy/10 transition-colors
                          px-4 py-2 rounded-lg text-navy font-medium text-sm">
                  ⬇ {item.file_name ?? 'Download File'}
                </a>
              )}
            </div>
          ))}
        </div>
      )}
    </div>

    <!-- ── Student progress table ─────────────────────────────────────── -->
    <div>
      <h2 class="font-semibold text-navy mb-4 text-lg">
        👥 Student Progress
        <span class="text-xs font-normal text-gray-400 ml-2">
          {studentStatuses?.length ?? 0} assigned
        </span>
      </h2>

      {!studentStatuses || studentStatuses.length === 0 ? (
        <div class="bg-white rounded-xl border border-dashed border-gray-300 px-6 py-10 text-center text-gray-400 italic text-sm">
          No students assigned to this assignment yet.
          <a href={`/admin/assignments/edit/${id}`} class="text-gold underline ml-1">Assign students →</a>
        </div>
      ) : (
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
          <table class="w-full">
            <thead class="bg-navy">
              <tr>
                <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider">Student</th>
                <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider">Status</th>
                <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider hidden md:table-cell">Assigned</th>
                <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider hidden md:table-cell">Completed</th>
                <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider">Notes</th>
              </tr>
            </thead>
            <tbody>
              {studentStatuses.map((sa: any) => {
                const student = sa.student as any;
                return (
                  <tr class="border-t border-gray-100 hover:bg-gray-50 transition-colors">
                    <td class="px-4 py-3">
                      <p class="font-medium text-navy text-sm">{student?.name ?? '—'}</p>
                      {student?.email && (
                        <p class="text-xs text-gray-400">{student.email}</p>
                      )}
                      {student?.access_token && (
                        <a href={`${BASE_URL}/homework/${student.access_token}`}
                           target="_blank"
                           class="text-xs text-gold underline underline-offset-2 mt-0.5 inline-block">
                          View their page ↗
                        </a>
                      )}
                    </td>
                    <td class="px-4 py-3">
                      <span class={`inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium ${statusClass[sa.status]}`}>
                        {statusLabel[sa.status] ?? sa.status}
                      </span>
                    </td>
                    <td class="px-4 py-3 text-gray-500 text-xs hidden md:table-cell">
                      {formatDate(sa.assigned_at)}
                    </td>
                    <td class="px-4 py-3 text-gray-500 text-xs hidden md:table-cell">
                      {sa.completed_at ? formatDate(sa.completed_at) : '—'}
                    </td>
                    <td class="px-4 py-3 max-w-xs">
                      {sa.student_notes ? (
                        <details>
                          <summary class="text-xs text-gold cursor-pointer underline underline-offset-2">
                            View notes
                          </summary>
                          <p class="text-xs text-gray-600 mt-2 whitespace-pre-wrap bg-gray-50 rounded p-2">
                            {sa.student_notes}
                          </p>
                        </details>
                      ) : (
                        <span class="text-xs text-gray-400 italic">No notes</span>
                      )}
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      )}
    </div>

  </div>
</AdminLayout>

<!-- Render FEN boards on load -->
<script>
import { Chessground } from 'chessground';

document.querySelectorAll<HTMLElement>('.fen-preview-board').forEach((el) => {
  const fen = el.dataset.fen ?? '';
  const ori = (el.dataset.orientation ?? 'white') as 'white' | 'black';
  if (fen) {
    Chessground(el, {
      fen,
      orientation: ori,
      viewOnly: true,
      coordinates: true,
      drawable: { enabled: false },
    });
  }
});
</script>

<style is:global>
  .fen-preview-board cg-board { background-size: cover; }
</style>
