---
/**
 * src/pages/admin/login.astro
 * Admin login — uses Supabase Auth signInWithPassword.
 * If already logged in, redirect straight to the dashboard.
 */
export const prerender = false;

import { createClient }      from '@supabase/supabase-js';
import { setSessionCookie, getSessionTokens } from '../../lib/auth';
import { supabaseAdmin }     from '../../lib/supabase-admin';

// If already logged in, skip to dashboard
const existingTokens = getSessionTokens(Astro.cookies);
if (existingTokens) {
  const { data: { user } } = await supabaseAdmin.auth.getUser(existingTokens.access_token);
  if (user) return Astro.redirect('/admin');
}

let errorMsg = '';

// ── Handle login POST ──────────────────────────────────────────────────────
if (Astro.request.method === 'POST') {
  const form     = await Astro.request.formData();
  const email    = (form.get('email')    ?? '').toString().trim();
  const password = (form.get('password') ?? '').toString();

  if (!email || !password) {
    errorMsg = 'Please enter both email and password.';
  } else {
    // Use anon client with persistSession:false so no localStorage is touched
    const supabase = createClient(
      import.meta.env.SUPABASE_URL,
      import.meta.env.SUPABASE_ANON_KEY,
      { auth: { persistSession: false, autoRefreshToken: false } },
    );

    const { data, error } = await supabase.auth.signInWithPassword({ email, password });

    if (error || !data.session) {
      errorMsg = error?.message ?? 'Invalid email or password.';
    } else {
      setSessionCookie(Astro.cookies, data.session, import.meta.env.PROD);
      return Astro.redirect('/admin');
    }
  }
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Admin Login | FM Dalton Perrine</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body class="font-inter bg-gray-50 min-h-screen flex items-center justify-center px-4">

    <div class="w-full max-w-sm">

      <!-- Logo / heading -->
      <div class="text-center mb-8">
        <span class="text-5xl">♟</span>
        <h1 class="font-playfair text-2xl font-bold text-navy mt-3">Admin Login</h1>
        <p class="text-gray-500 text-sm mt-1">FM Dalton Perrine · Chess Coaching</p>
      </div>

      <!-- Error message -->
      {errorMsg && (
        <div class="bg-red-50 border border-red-200 text-red-700 rounded-lg px-4 py-3 text-sm mb-4">
          {errorMsg}
        </div>
      )}

      <!-- Login form -->
      <form method="POST" class="bg-white border border-gray-200 rounded-2xl shadow-sm p-8 space-y-5">

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="email">Email</label>
          <input
            id="email"
            type="email"
            name="email"
            required
            autocomplete="email"
            placeholder="you@example.com"
            class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-gold focus:border-transparent"
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="password">Password</label>
          <input
            id="password"
            type="password"
            name="password"
            required
            autocomplete="current-password"
            placeholder="••••••••"
            class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-gold focus:border-transparent"
          />
        </div>

        <button
          type="submit"
          class="w-full bg-gold text-navy font-semibold py-2.5 rounded-lg text-sm hover:bg-gold-hover transition-colors"
        >
          Sign In
        </button>

      </form>

      <p class="text-center text-xs text-gray-400 mt-6">
        Private admin area — not for students.
      </p>

    </div>

  </body>
</html>

<style>
  .font-inter    { font-family: 'Inter', sans-serif; }
  .font-playfair { font-family: 'Playfair Display', serif; }
  .text-navy     { color: #1B1F3B; }
  .bg-gold       { background-color: #C9A227; }
  .bg-gold-hover { background-color: #b8921f; }
  .hover\:bg-gold-hover:hover { background-color: #b8921f; }
  .focus\:ring-gold:focus { --tw-ring-color: #C9A227; }
</style>
