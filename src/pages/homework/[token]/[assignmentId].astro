---
/**
 * src/pages/homework/[token]/[assignmentId].astro
 *
 * Individual Assignment Page — student-facing, SSR, no login required.
 * URL: /homework/<access_token>/<assignment_id>
 *
 * Features:
 *  - 5 item types: text, fen (chessground board), pgn, file, link
 *  - Countdown timer for FEN items with timer_seconds
 *  - Interactive chessground boards with reset + flip
 *  - PGN display with copy button
 *  - Student notes textarea — saved client-side via Supabase anon client
 *  - Status flow: pending → in_progress → completed (client-side Supabase)
 */
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import { getStudentByToken, supabaseAdmin } from '../../../lib/supabase-admin';
import { parseVideoUrl } from '../../../lib/video';

// ── Validate token + assignment access ────────────────────────────────────────
const { token, assignmentId } = Astro.params;

if (!token || !assignmentId) return Astro.redirect('/404');

const student = await getStudentByToken(token);
if (!student) return new Response(null, { status: 404 });

// Fetch the student_assignment record (ensures this student owns this assignment)
const { data: sa, error: saError } = await supabaseAdmin
  .from('student_assignments')
  .select(`
    *,
    assignment:assignments (
      id,
      title,
      lesson_date,
      assignment_items (*)
    )
  `)
  .eq('student_id', student.id)
  .eq('assignment_id', assignmentId)
  .single();

if (saError || !sa) return new Response(null, { status: 404 });

const assignment = sa.assignment as any;
const items = [...(assignment?.assignment_items ?? [])].sort(
  (a: any, b: any) => a.item_order - b.item_order
);

// ── Resolve any recording items in the assignment ─────────────────────────────
// If any item has item_type === 'recording', fetch the recording records so we
// can embed them directly in the page (server-side, using the service role key).
const recordingIds = items
  .filter((item: any) => item.item_type === 'recording' && item.content)
  .map((item: any) => item.content as string);

const recordingsMap: Record<string, any> = {};
if (recordingIds.length > 0) {
  const { data: recs } = await supabaseAdmin
    .from('lesson_recordings')
    .select('*')
    .in('id', recordingIds);
  for (const rec of recs ?? []) {
    recordingsMap[rec.id] = rec;
  }
}

// Pass Supabase connection details to client via define:vars
const supabaseUrl     = import.meta.env.SUPABASE_URL      as string;
const supabaseAnonKey = import.meta.env.SUPABASE_ANON_KEY as string;

// ── Helpers ───────────────────────────────────────────────────────────────────
function formatDate(d: string | null) {
  if (!d) return '';
  return new Date(d).toLocaleDateString('en-US', {
    weekday: 'long', year: 'numeric', month: 'long', day: 'numeric',
  });
}
function formatTimer(s: number) {
  return `${Math.floor(s / 60)}:${String(s % 60).padStart(2, '0')}`;
}

const statusLabel: Record<string, string> = {
  pending:     '⬜ Not Started',
  in_progress: '🔄 In Progress',
  completed:   '✅ Completed',
};
const statusClass: Record<string, string> = {
  pending:     'bg-gray-100 text-gray-700',
  in_progress: 'bg-amber-50 text-amber-700 border border-amber-200',
  completed:   'bg-emerald-50 text-emerald-700 border border-emerald-200',
};
---

<Layout
  title={`${assignment.title} | Homework | FM Dalton Perrine`}
  description={`Homework assignment: ${assignment.title}`}
  noindex={true}
>
  <!-- Chessground CSS from CDN -->
  <Fragment slot="head">
    <link rel="stylesheet" href="https://unpkg.com/chessground@9.1.1/assets/chessground.base.css" />
    <link rel="stylesheet" href="https://unpkg.com/chessground@9.1.1/assets/chessground.brown.css" />
    <link rel="stylesheet" href="https://unpkg.com/chessground@9.1.1/assets/chessground.cburnett.css" />
  </Fragment>

  <!-- ── Page Header (navy) ─────────────────────────────────────────────────── -->
  <section class="bg-navy pt-6 pb-8">
    <div class="container-max">

      <!-- Breadcrumb -->
      <a href={`/homework/${token}`}
         class="text-gold/80 hover:text-gold text-sm transition-colors inline-flex items-center gap-1 mb-5">
        ← Back to all assignments
      </a>

      <!-- Title + status -->
      <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
        <div>
          <h1 class="font-playfair text-3xl lg:text-4xl font-bold text-white">
            {assignment.title}
          </h1>
          {assignment.lesson_date && (
            <p class="text-white/60 text-sm mt-2">
              📅 Lesson: {formatDate(assignment.lesson_date)}
            </p>
          )}
        </div>
        <span id="status-badge"
              class={`inline-flex items-center px-3 py-1.5 rounded-full text-sm font-medium flex-shrink-0 ${statusClass[sa.status]}`}>
          {statusLabel[sa.status]}
        </span>
      </div>

      <!-- Progress context for completed assignments -->
      {sa.status === 'completed' && sa.completed_at && (
        <p class="mt-3 text-emerald-300 text-sm">
          ✅ Completed on {formatDate(sa.completed_at)}
        </p>
      )}
    </div>
  </section>

  <!-- ── Assignment Items ───────────────────────────────────────────────────── -->
  <section class="section-pad bg-off-white">
    <div class="container-max space-y-6">

      {items.length === 0 ? (
        <div class="card text-center py-12 text-text-secondary italic">
          This assignment has no items yet. Check back soon!
        </div>
      ) : (
        items.map((item: any) => (
          <div class="card" data-item-id={item.id}>

            <!-- ── Item header: type badge + optional timer ── -->
            <div class="flex flex-wrap items-center justify-between gap-3 mb-4">
              <span class="inline-flex items-center gap-1.5 text-xs bg-navy/8 text-navy px-3 py-1 rounded-full font-medium uppercase tracking-wide">
                {item.item_type === 'text'  && <span>📝 Text</span>}
                {item.item_type === 'fen'   && <span>♟ Position</span>}
                {item.item_type === 'pgn'   && <span>📖 Game / PGN</span>}
                {item.item_type === 'file'  && <span>📎 File</span>}
                {item.item_type === 'link'  && <span>🔗 Link</span>}
              </span>

              {/* Countdown timer badge for FEN items */}
              {item.item_type === 'fen' && item.timer_seconds && item.timer_seconds > 0 && (
                <div class="flex items-center gap-2"
                     data-timer
                     data-timer-seconds={item.timer_seconds}>
                  <span class="text-amber-600 text-xs font-medium">⏱ Limit:</span>
                  <span data-timer-display
                        class="font-mono text-base font-bold text-amber-700 tabular-nums min-w-[3.5rem] text-center">
                    {formatTimer(item.timer_seconds)}
                  </span>
                  <button data-timer-btn
                          class="text-xs bg-amber-50 hover:bg-amber-100 border border-amber-200 text-amber-700
                                 font-medium px-3 py-1 rounded-full transition-colors">
                    ▶ Start
                  </button>
                </div>
              )}
            </div>

            <!-- Item title -->
            {item.title && (
              <h3 class="font-semibold text-navy text-base mb-3">{item.title}</h3>
            )}

            <!-- ── TEXT ── -->
            {item.item_type === 'text' && (
              <p class="text-text-primary whitespace-pre-wrap leading-relaxed">
                {item.content}
              </p>
            )}

            <!-- ── FEN (chessground board) ── -->
            {item.item_type === 'fen' && (
              <div>
                <!-- Board container -->
                <div
                  data-fen-board
                  data-fen={item.content}
                  data-orientation={item.metadata?.orientation ?? 'white'}
                  style="width:320px;height:320px;border:1px solid #d1d5db;border-radius:6px;overflow:hidden;max-width:100%;"
                ></div>

                <!-- Board controls -->
                <div class="flex flex-wrap gap-2 mt-3">
                  <button data-reset-board
                          class="inline-flex items-center gap-1.5 text-sm px-3 py-1.5 rounded-lg border border-navy/20
                                 text-navy hover:bg-navy/5 transition-colors font-medium">
                    ↺ Reset
                  </button>
                  <button data-flip-board
                          class="inline-flex items-center gap-1.5 text-sm px-3 py-1.5 rounded-lg border border-navy/20
                                 text-navy hover:bg-navy/5 transition-colors font-medium">
                    ⇅ Flip Board
                  </button>
                </div>

                <!-- FEN string (collapsible) -->
                <details class="mt-3">
                  <summary class="text-xs text-text-secondary cursor-pointer hover:text-navy">
                    Show FEN string
                  </summary>
                  <code class="block bg-gray-50 border border-gray-200 rounded p-2 text-xs font-mono text-navy break-all mt-2">
                    {item.content}
                  </code>
                </details>
              </div>
            )}

            <!-- ── PGN ── -->
            {item.item_type === 'pgn' && (
              <div data-pgn-block>
                <div class="flex items-center justify-between mb-2">
                  <span class="text-xs text-text-secondary">Game notation (PGN):</span>
                  <button data-copy-pgn
                          class="text-xs bg-navy/5 hover:bg-navy/10 border border-navy/15
                                 text-navy px-3 py-1 rounded-full font-medium transition-colors">
                    📋 Copy PGN
                  </button>
                </div>
                <pre class="bg-gray-50 border border-gray-200 rounded-lg p-4 text-xs font-mono text-navy
                            overflow-x-auto whitespace-pre-wrap leading-relaxed">
                  {item.content}
                </pre>
              </div>
            )}

            <!-- ── LINK ── -->
            {item.item_type === 'link' && (
              <a href={item.content ?? '#'}
                 target="_blank"
                 rel="noopener noreferrer"
                 class="inline-flex items-center gap-2 text-gold underline underline-offset-2 font-medium
                        hover:text-gold/80 transition-colors">
                {item.title ?? item.content}
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            )}

            <!-- ── FILE ── -->
            {item.item_type === 'file' && item.file_url && (
              <a href={item.file_url}
                 target="_blank"
                 rel="noopener noreferrer"
                 class="inline-flex items-center gap-3 bg-navy/5 hover:bg-navy/10 transition-colors
                        px-5 py-3 rounded-xl text-navy font-medium text-sm border border-navy/10">
                <svg class="w-5 h-5 text-gold flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                </svg>
                <span>{item.file_name ?? 'Download File'}</span>
              </a>
            )}

            <!-- ── LESSON RECORDING ── -->
            {item.item_type === 'recording' && (() => {
              const rec = recordingsMap[item.content ?? ''];
              if (!rec) return (
                <p class="text-text-secondary italic text-sm">Recording not available.</p>
              );
              const videoInfo = parseVideoUrl(rec.video_url);
              return (
                <div data-recording-card>
                  <p class="text-sm text-text-secondary mb-3">
                    📅 Lesson: {formatDate(rec.lesson_date)}
                  </p>
                  {rec.notes && (
                    <p class="text-sm leading-relaxed bg-navy/4 rounded-xl p-4 mb-4">
                      <span class="font-semibold text-navy">Coach's notes: </span>
                      {rec.notes}
                    </p>
                  )}
                  <button data-expand-player
                          class="inline-flex items-center gap-2 bg-gold text-navy font-semibold
                                 px-4 py-2 rounded-lg text-sm hover:bg-gold/90 transition-colors mb-3">
                    ▶ Watch Recording
                  </button>
                  <div data-player-wrap class="hidden">
                    {videoInfo.embedUrl ? (
                      <>
                        <div class="relative w-full max-w-2xl rounded-xl overflow-hidden bg-black"
                             style="aspect-ratio: 16 / 9;">
                          <iframe
                            src={videoInfo.embedUrl}
                            class="absolute inset-0 w-full h-full"
                            allow="autoplay"
                            allowfullscreen
                            loading="lazy"
                          ></iframe>
                        </div>
                        <a href={rec.video_url}
                           target="_blank"
                           rel="noopener noreferrer"
                           class="mt-3 inline-block text-sm text-gold underline underline-offset-2">
                          Open in Google Drive ↗
                        </a>
                      </>
                    ) : (
                      <a href={rec.video_url}
                         target="_blank"
                         rel="noopener noreferrer"
                         class="inline-flex items-center gap-2 text-gold font-medium underline underline-offset-2">
                        Open Recording in Google Drive →
                      </a>
                    )}
                  </div>
                </div>
              );
            })()}

          </div>
        ))
      )}

      <!-- ── Notes + Status Actions ──────────────────────────────────────────── -->
      <div class="card" id="notes-section">
        <h2 class="font-playfair text-xl font-bold text-navy mb-1">Your Notes</h2>
        <p class="text-text-secondary text-sm mb-4">
          Jot down your thoughts, questions, or what you learned. Coach Dalton can see these.
        </p>

        {sa.status !== 'completed' ? (
          <>
            <textarea
              id="notes-textarea"
              rows="5"
              placeholder="Write your thoughts here... What did you find difficult? What surprised you? What will you work on?"
              class="w-full border border-navy/20 rounded-xl px-4 py-3 text-sm text-navy
                     placeholder-navy/35 focus:outline-none focus:ring-2 focus:ring-gold
                     focus:border-transparent resize-y leading-relaxed"
            >{sa.student_notes ?? ''}</textarea>

            <div class="flex flex-wrap items-center gap-3 mt-4">
              <button id="save-notes-btn"
                      class="inline-flex items-center gap-2 bg-white border-2 border-navy text-navy
                             font-semibold px-5 py-2.5 rounded-lg text-sm hover:bg-navy/5
                             transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
                💾 Save Notes
              </button>
              <button id="mark-complete-btn"
                      class="inline-flex items-center gap-2 bg-gold text-navy font-semibold
                             px-5 py-2.5 rounded-lg text-sm hover:bg-gold/90 transition-colors
                             disabled:opacity-50 disabled:cursor-not-allowed">
                ✅ Mark as Complete
              </button>
              <span id="save-status" class="text-sm text-text-secondary transition-opacity"></span>
            </div>
          </>
        ) : (
          <>
            <div class="bg-emerald-50 border border-emerald-200 rounded-xl p-4 mb-4">
              <p class="text-emerald-700 font-semibold text-sm mb-1">✅ Assignment completed!</p>
              {sa.completed_at && (
                <p class="text-emerald-600 text-xs">on {formatDate(sa.completed_at)}</p>
              )}
            </div>
            {sa.student_notes ? (
              <div>
                <p class="text-sm font-medium text-text-primary mb-2">Your notes:</p>
                <p class="bg-gray-50 border border-gray-200 rounded-xl p-4 text-sm text-navy whitespace-pre-wrap leading-relaxed">
                  {sa.student_notes}
                </p>
              </div>
            ) : (
              <p class="text-sm text-text-secondary italic">No notes submitted.</p>
            )}
            <button id="reopen-btn"
                    class="mt-4 inline-flex items-center gap-2 text-sm text-text-secondary hover:text-navy
                           underline underline-offset-2 transition-colors">
              ↩ Reopen & edit notes
            </button>
          </>
        )}
      </div>

    </div>
  </section>

  <!-- ── Footer CTA ─────────────────────────────────────────────────────────── -->
  <section class="bg-navy section-pad text-center">
    <div class="container-max space-y-3">
      <a href={`/homework/${token}`}
         class="inline-flex items-center gap-2 text-gold underline underline-offset-2 text-sm">
        ← Back to all assignments
      </a>
      <p class="text-white/60 text-sm">
        Questions?
        <a href="mailto:NextLevelChessCoaching@gmail.com" class="text-gold underline ml-1">
          Email Coach Dalton
        </a>
      </p>
    </div>
  </section>

</Layout>

<!-- ── Bridge server data → client window variables ──────────────────────────── -->
<script define:vars={{
  saId:            sa.id,
  saStatus:        sa.status,
  supabaseUrl,
  supabaseAnonKey,
}}>
  window.__SA_ID   = saId;
  window.__STATUS  = saStatus;
  window.__SB_URL  = supabaseUrl;
  window.__SB_ANON = supabaseAnonKey;
</script>

<!-- ── Client-side interactivity (module script) ─────────────────────────────── -->
<script>
import { Chessground } from 'chessground';
import { createClient } from '@supabase/supabase-js';

// Supabase anon client (RLS-protected — students can only update their own rows)
const supabase = createClient(
  (window as any).__SB_URL  as string,
  (window as any).__SB_ANON as string,
);

// ────────────────────────────────────────────────────────────────────────────
// 1. Auto-mark as in_progress when a pending assignment is opened
// ────────────────────────────────────────────────────────────────────────────
if ((window as any).__STATUS === 'pending') {
  supabase
    .from('student_assignments')
    .update({ status: 'in_progress' })
    .eq('id', (window as any).__SA_ID)
    .then(() => {
      (window as any).__STATUS = 'in_progress';
      // Update the badge
      const badge = document.getElementById('status-badge');
      if (badge) {
        badge.textContent = '🔄 In Progress';
        badge.className = 'inline-flex items-center px-3 py-1.5 rounded-full text-sm font-medium flex-shrink-0 bg-amber-50 text-amber-700 border border-amber-200';
      }
    });
}

// ────────────────────────────────────────────────────────────────────────────
// 2. Chessground boards
// ────────────────────────────────────────────────────────────────────────────
document.querySelectorAll<HTMLElement>('[data-fen-board]').forEach((el) => {
  const fen = el.dataset.fen ?? '';
  const ori = (el.dataset.orientation ?? 'white') as 'white' | 'black';
  if (!fen) return;

  const cg = Chessground(el, {
    fen,
    orientation: ori,
    movable: {
      color: 'both',
      free: true,
      showDests: false,
    },
    coordinates: true,
    drawable: { enabled: true },
  });

  const card = el.closest<HTMLElement>('[data-item-id]');

  // Reset button → restore original FEN
  card?.querySelector<HTMLButtonElement>('[data-reset-board]')?.addEventListener('click', () => {
    cg.set({ fen });
  });

  // Flip button → toggle orientation
  card?.querySelector<HTMLButtonElement>('[data-flip-board]')?.addEventListener('click', () => {
    cg.toggleOrientation();
  });
});

// ────────────────────────────────────────────────────────────────────────────
// 3. Countdown timers
// ────────────────────────────────────────────────────────────────────────────
document.querySelectorAll<HTMLElement>('[data-timer]').forEach((timerEl) => {
  const totalSeconds = parseInt(timerEl.dataset.timerSeconds ?? '0', 10);
  if (!totalSeconds) return;

  let remaining = totalSeconds;
  let interval: ReturnType<typeof setInterval> | null = null;

  const display = timerEl.querySelector<HTMLElement>('[data-timer-display]');
  const btn     = timerEl.querySelector<HTMLButtonElement>('[data-timer-btn]');

  function fmt(s: number) {
    return `${Math.floor(s / 60)}:${String(s % 60).padStart(2, '0')}`;
  }

  if (display) display.textContent = fmt(remaining);

  btn?.addEventListener('click', () => {
    if (interval) {
      // Pause
      clearInterval(interval);
      interval = null;
      if (btn) btn.textContent = '▶ Resume';
    } else {
      if (remaining <= 0) return;
      if (btn) btn.textContent = '⏸ Pause';
      interval = setInterval(() => {
        remaining--;
        if (display) display.textContent = fmt(remaining);
        if (remaining <= 0) {
          clearInterval(interval!);
          interval = null;
          if (btn) {
            btn.textContent = "⏱ Time's up!";
            btn.disabled = true;
          }
          if (display) {
            display.classList.remove('text-amber-700');
            display.classList.add('text-red-600', 'font-extrabold');
          }
        }
      }, 1000);
    }
  });
});

// ────────────────────────────────────────────────────────────────────────────
// 4. Lesson recording expand/collapse
// ────────────────────────────────────────────────────────────────────────────
document.querySelectorAll<HTMLElement>('[data-recording-card]').forEach((card) => {
  const expandBtn  = card.querySelector<HTMLButtonElement>('[data-expand-player]');
  const playerWrap = card.querySelector<HTMLElement>('[data-player-wrap]');
  expandBtn?.addEventListener('click', () => {
    const isOpen = !playerWrap?.classList.contains('hidden');
    playerWrap?.classList.toggle('hidden', isOpen);
    if (expandBtn) expandBtn.textContent = isOpen ? '▶ Watch Recording' : '▲ Hide Player';
  });
});

// ────────────────────────────────────────────────────────────────────────────
// 5. PGN copy buttons
// ────────────────────────────────────────────────────────────────────────────
document.querySelectorAll<HTMLButtonElement>('[data-copy-pgn]').forEach((btn) => {
  btn.addEventListener('click', () => {
    const block = btn.closest<HTMLElement>('[data-pgn-block]');
    const text  = block?.querySelector('pre')?.textContent?.trim() ?? '';
    navigator.clipboard.writeText(text).then(() => {
      btn.textContent = '✅ Copied!';
      setTimeout(() => { btn.textContent = '📋 Copy PGN'; }, 2500);
    });
  });
});

// ────────────────────────────────────────────────────────────────────────────
// 6. Save notes
// ────────────────────────────────────────────────────────────────────────────
const saveBtn     = document.getElementById('save-notes-btn') as HTMLButtonElement | null;
const notesArea   = document.getElementById('notes-textarea') as HTMLTextAreaElement | null;
const saveStatus  = document.getElementById('save-status');

async function saveNotes(silent = false) {
  if (!notesArea) return;
  const notes     = notesArea.value;
  const curStatus = (window as any).__STATUS as string;
  // If currently pending (shouldn't happen since we auto-update, but safety net)
  const newStatus = curStatus === 'pending' ? 'in_progress' : curStatus;

  if (!silent && saveBtn) saveBtn.disabled = true;
  if (!silent && saveStatus) saveStatus.textContent = 'Saving…';

  const { error } = await supabase
    .from('student_assignments')
    .update({ student_notes: notes, status: newStatus })
    .eq('id', (window as any).__SA_ID);

  if (!silent) {
    if (error) {
      if (saveStatus) saveStatus.textContent = '❌ Error saving. Try again.';
    } else {
      (window as any).__STATUS = newStatus;
      if (saveStatus) {
        saveStatus.textContent = '✅ Saved!';
        setTimeout(() => { if (saveStatus) saveStatus.textContent = ''; }, 3000);
      }
    }
    if (saveBtn) saveBtn.disabled = false;
  }
}

saveBtn?.addEventListener('click', () => saveNotes(false));

// Auto-save every 90 seconds if there's content
setInterval(() => {
  if (notesArea?.value?.trim()) saveNotes(true);
}, 90_000);

// ────────────────────────────────────────────────────────────────────────────
// 7. Mark as Complete
// ────────────────────────────────────────────────────────────────────────────
const completeBtn = document.getElementById('mark-complete-btn') as HTMLButtonElement | null;

completeBtn?.addEventListener('click', async () => {
  if (!confirm('Mark this assignment as complete? You can still view and edit your notes after.')) return;
  completeBtn.disabled = true;
  completeBtn.textContent = 'Saving…';

  const notes = notesArea?.value ?? '';

  const { error } = await supabase
    .from('student_assignments')
    .update({
      status:        'completed',
      completed_at:  new Date().toISOString(),
      student_notes: notes,
    })
    .eq('id', (window as any).__SA_ID);

  if (error) {
    completeBtn.disabled = false;
    completeBtn.textContent = '✅ Mark as Complete';
    alert('Error saving. Please try again.');
  } else {
    window.location.reload();
  }
});

// ────────────────────────────────────────────────────────────────────────────
// 8. Reopen (completed → in_progress, shows edit UI without page reload)
// ────────────────────────────────────────────────────────────────────────────
const reopenBtn = document.getElementById('reopen-btn') as HTMLButtonElement | null;

reopenBtn?.addEventListener('click', async () => {
  reopenBtn.disabled = true;
  const { error } = await supabase
    .from('student_assignments')
    .update({ status: 'in_progress' })
    .eq('id', (window as any).__SA_ID);

  if (!error) {
    (window as any).__STATUS = 'in_progress';
    window.location.reload();
  } else {
    reopenBtn.disabled = false;
    alert('Error. Please try again.');
  }
});
</script>

<style is:global>
  /* Ensure chessground boards fill their container correctly */
  [data-fen-board] cg-board {
