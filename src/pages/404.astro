---
import Layout from '../layouts/Layout.astro';
---
<Layout title="404 – Page Not Found | FM Dalton Perrine">
  <section class="section-pad bg-off-white min-h-[60vh] flex items-center">
    <div class="container-max text-center flex flex-col items-center gap-6">
      <span class="text-7xl" aria-hidden="true">♟</span>
      <h1 class="font-playfair text-4xl font-bold text-navy">Page Not Found</h1>
      <p class="font-inter text-text-secondary text-lg max-w-sm">
        Looks like that square doesn't exist on the board. Let's get you back to the game.
      </p>
      <a href="/" class="btn-gold">Back to Home</a>
    </div>
  </section>
</Layout>
