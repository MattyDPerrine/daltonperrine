---
/**
 * src/layouts/AdminLayout.astro
 * Streamlined layout for the admin dashboard — no public Navbar/Footer.
 * Includes the admin top bar with logo and logout button.
 */
import '../styles/global.css';

interface Props {
  title?:       string;
  description?: string;
  /** Optional page-level action buttons rendered in the header bar */
  headerActions?: string;
}

const {
  title       = 'Admin Dashboard | FM Dalton Perrine',
  description = 'Private admin dashboard.',
} = Astro.props;

const user = Astro.locals.user;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <slot name="head" />
  </head>

  <body class="font-inter bg-gray-50 text-gray-900 min-h-screen">

    <!-- ── Admin top bar ─────────────────────────────────────────────────── -->
    <header class="bg-navy border-b border-white/10 sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-14 flex items-center justify-between">

        <!-- Left: logo / title -->
        <a href="/admin" class="flex items-center gap-2 text-white hover:text-gold transition-colors">
          <span class="text-gold text-xl">♟</span>
          <span class="font-playfair font-bold text-sm tracking-wide">Admin Dashboard</span>
        </a>

        <!-- Center: nav links -->
        <nav class="hidden md:flex items-center gap-1">
          <a href="/admin"
             class="text-white/70 hover:text-white hover:bg-white/10 px-3 py-1.5 rounded text-sm transition-colors">
            Dashboard
          </a>
          <a href="/admin/students"
             class="text-white/70 hover:text-white hover:bg-white/10 px-3 py-1.5 rounded text-sm transition-colors">
            Students
          </a>
          <a href="/admin/assignments"
             class="text-white/70 hover:text-white hover:bg-white/10 px-3 py-1.5 rounded text-sm transition-colors">
            Assignments
          </a>
          <a href="/admin/recordings"
             class="text-white/70 hover:text-white hover:bg-white/10 px-3 py-1.5 rounded text-sm transition-colors">
            Recordings
          </a>
        </nav>

        <!-- Right: user email + logout -->
        <div class="flex items-center gap-3">
          {user && (
            <span class="text-white/50 text-xs hidden sm:block">{user.email}</span>
          )}
          <form method="POST" action="/admin/logout">
            <button
              type="submit"
              class="text-white/70 hover:text-white border border-white/20 hover:border-white/40 px-3 py-1 rounded text-xs transition-colors"
            >
              Logout
            </button>
          </form>
        </div>

      </div>
    </header>

    <!-- ── Page content ──────────────────────────────────────────────────── -->
    <main>
      <slot />
    </main>

  </body>
</html>

<style is:global>
  /* Admin-specific utilities */
  .admin-page-header {
    @apply bg-white border-b border-gray-200 px-4 sm:px-6 lg:px-8 py-5;
  }
  .admin-page-body {
    @apply max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8;
  }
  .admin-card {
    @apply bg-white rounded-xl border border-gray-200 shadow-sm;
  }
  .admin-btn-primary {
    @apply inline-flex items-center gap-2 bg-gold text-navy font-semibold px-4 py-2 rounded-lg text-sm
           hover:bg-gold-hover transition-colors cursor-pointer;
  }
  .admin-btn-secondary {
    @apply inline-flex items-center gap-2 bg-white text-navy font-medium px-4 py-2 rounded-lg text-sm
           border border-gray-200 hover:bg-gray-50 transition-colors cursor-pointer;
  }
  .admin-btn-danger {
    @apply inline-flex items-center gap-2 bg-red-50 text-red-700 font-medium px-3 py-1.5 rounded-lg
           text-sm border border-red-200 hover:bg-red-100 transition-colors cursor-pointer;
  }
  .admin-input {
    @apply w-full border border-gray-300 rounded-lg px-3 py-2 text-sm text-gray-900
           placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-gold focus:border-transparent
           bg-white;
  }
  .admin-label {
    @apply block text-sm font-medium text-gray-700 mb-1;
  }
  .admin-table th {
    @apply px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider;
  }
  .admin-table td {
    @apply px-4 py-3 text-sm;
  }
  .admin-table tr {
    @apply border-t border-gray-100;
  }
  .status-pending     { @apply inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600; }
  .status-in_progress { @apply inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-amber-50 text-amber-700; }
  .status-completed   { @apply inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-emerald-50 text-emerald-700; }
</style>
