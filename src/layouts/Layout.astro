---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import SEO    from '../components/SEO.astro';
import '../styles/global.css';

interface Props {
  /** Page <title> */
  title?:         string;
  /** Meta description */
  description?:   string;
  /** OG image path or URL (defaults to /og-default.png) */
  ogImage?:       string;
  /** OG type — 'website' | 'article' (defaults to 'website') */
  ogType?:        'website' | 'article';
  /** Set true to add noindex/nofollow (admin/homework pages) */
  noindex?:       boolean;
  /** ISO date string for blog posts (article:published_time) */
  articleDate?:   string;
  /** Article author for blog posts (defaults to "Dalton Perrine") */
  articleAuthor?: string;
}

const {
  title         = 'FM Dalton Perrine | Online Chess Coach — Personalized Lessons for All Levels',
  description   = 'FIDE Master Dalton Perrine offers personalized online chess coaching for players of all levels. 12+ years of experience, 2300+ peak rating, Chessable author. Book your first lesson today.',
  ogImage,
  ogType,
  noindex,
  articleDate,
  articleAuthor,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <!-- SEO: all meta / OG / Twitter / canonical in one place -->
    <SEO
      title={title}
      description={description}
      ogImage={ogImage}
      ogType={ogType}
      noindex={noindex}
      articleDate={articleDate}
      articleAuthor={articleAuthor}
    />

    <!-- Google Fonts preconnect + stylesheet -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,600&family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Page-specific head content (JSON-LD structured data, etc.) -->
    <slot name="head" />
  </head>

  <body class="font-inter text-text-primary bg-white">
    <Navbar />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
