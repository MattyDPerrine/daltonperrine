---
/**
 * SEO.astro — single source of truth for all <head> meta content.
 * Drop this at the top of every page's <head> section via Layout.astro.
 */

interface Props {
  /** Page <title> (required). */
  title: string;
  /** Meta description (required). */
  description: string;
  /** Canonical URL. Defaults to the current page URL. */
  canonicalURL?: string;
  /** Absolute path or URL to the OG image. Defaults to /og-default.png. */
  ogImage?: string;
  /** OG type. Defaults to "website". Blog posts use "article". */
  ogType?: 'website' | 'article';
  /** Set true for admin/homework pages to prevent Google indexing. */
  noindex?: boolean;
  /** ISO date string for article:published_time (blog posts only). */
  articleDate?: string;
  /** Article author (blog posts only). Defaults to "Dalton Perrine". */
  articleAuthor?: string;
}

const {
  title,
  description,
  canonicalURL:  canonicalURLProp,
  ogImage        = '/og-default.png',
  ogType         = 'website',
  noindex        = false,
  articleDate,
  articleAuthor  = 'Dalton Perrine',
} = Astro.props;

// Resolve site base — falls back to hard-coded domain if Astro.site is undefined
const siteBase    = Astro.site ?? new URL('https://daltonperrine.com');
const canonicalURL = canonicalURLProp ?? new URL(Astro.url.pathname, siteBase).href;

// Always produce a fully-qualified OG image URL
const ogImageURL  = ogImage.startsWith('http')
  ? ogImage
  : new URL(ogImage, siteBase).href;
---

<!-- ── Charset & Viewport (always first) ──────────────────────────────── -->
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />

<!-- ── Favicon ─────────────────────────────────────────────────────────── -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

<!-- ── Theme color (matches dark navy brand) ───────────────────────────── -->
<meta name="theme-color" content="#1B1F3B" />

<!-- ── Primary Meta Tags ───────────────────────────────────────────────── -->
<title>{title}</title>
<meta name="description"  content={description} />
<meta name="author"       content="Dalton Perrine" />
<link rel="canonical"     href={canonicalURL} />

{noindex && (
  <meta name="robots" content="noindex, nofollow" />
)}

<!-- ── Open Graph / Facebook ──────────────────────────────────────────── -->
<meta property="og:type"        content={ogType} />
<meta property="og:url"         content={canonicalURL} />
<meta property="og:title"       content={title} />
<meta property="og:description" content={description} />
<meta property="og:image"       content={ogImageURL} />
<meta property="og:site_name"   content="FM Dalton Perrine" />
<meta property="og:locale"      content="en_US" />

<!-- ── Twitter Card ────────────────────────────────────────────────────── -->
<meta name="twitter:card"        content="summary_large_image" />
<meta name="twitter:url"         content={canonicalURL} />
<meta name="twitter:title"       content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image"       content={ogImageURL} />

<!-- ── Article-specific (only rendered for ogType="article") ───────────── -->
{ogType === 'article' && (
  <meta property="article:author" content={articleAuthor} />
)}
{ogType === 'article' && articleDate && (
  <meta property="article:published_time" content={articleDate} />
)}
