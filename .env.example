# ─── Supabase ────────────────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API

# Project URL (safe to expose in browser code)
SUPABASE_URL=https://your-project-ref.supabase.co

# Anon / public key — subject to Row Level Security (safe for SSR page code)
SUPABASE_ANON_KEY=your_anon_key_here

# Service role key — BYPASSES Row Level Security. NEVER expose to the browser.
# Used only in supabase-admin.ts (server-side admin operations).
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── Admin ───────────────────────────────────────────────────────────────────
# The email address you use to log in to the admin dashboard.
# Must match the email in your Supabase Auth → Users table.
ADMIN_EMAIL=your-email@example.com
